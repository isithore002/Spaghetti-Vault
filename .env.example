# Pacifica
PACIFICA_ENV=testnet
PACIFICA_TESTNET_URL=https://test-api.pacifica.fi/api/v1
PACIFICA_MAINNET_URL=https://api.pacifica.fi/api/v1
PACIFICA_WS_TESTNET=wss://test-stream.pacifica.fi
PACIFICA_WS_MAINNET=wss://stream.pacifica.fi

# Vault builder keypair identity
VAULT_PRIVATE_KEY=<base58_encoded_private_key>
VAULT_BUILDER_CODE=SPAGHETTIVAULT1

# Strategy parameters
FUNDING_RATE_THRESHOLD=0.0001
MAX_LEVERAGE=3
STOP_LOSS_PCT=0.05
MARGIN_HEALTH_MIN=0.25
PERFORMANCE_FEE_PCT=0.15
LOOP_INTERVAL_SECONDS=60

# Optional backend DB path
DB_PATH=vault.db

# Frontend
NEXT_PUBLIC_PRIVY_APP_ID=<your_privy_app_id>
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
